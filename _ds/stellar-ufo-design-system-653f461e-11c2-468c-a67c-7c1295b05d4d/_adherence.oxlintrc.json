{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/forms/**",
              "components/marketing/**",
              "ui_kits/company_profile/**",
              "ui_kits/landing/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Fredoka|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Fredoka, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|solid|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, solid, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:mint|coral|navy|yellow|glass)$/]",
        "message": "<Badge> tone must be one of 'mint' | 'coral' | 'navy' | 'yellow' | 'glass'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BrandMark'] > JSXAttribute > JSXIdentifier[name!=/^(?:logoSrc|wordmark|descriptor|size|tone|style|key|ref|className|style|children)$/]",
        "message": "<BrandMark> doesn't accept that prop. Declared props: logoSrc, wordmark, descriptor, size, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='BrandMark'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:navy|ivory)$/]",
        "message": "<BrandMark> tone must be one of 'navy' | 'ivory'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|href|icon|iconRight|disabled|type|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, href, icon, iconRight, disabled, type, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|mint|ghost|onDark)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'mint' | 'ghost' | 'onDark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Capsule'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|size|float|style|key|ref|className|style|children)$/]",
        "message": "<Capsule> doesn't accept that prop. Declared props: color, size, float, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Capsule'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:coral|mint|yellow|glass|softcoral)$/]",
        "message": "<Capsule> color must be one of 'coral' | 'mint' | 'yellow' | 'glass' | 'softcoral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|interactive|pad|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, tone, interactive, pad, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:light|solid|glass|dark)$/]",
        "message": "<Card> tone must be one of 'light' | 'solid' | 'glass' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FlowStep'] > JSXAttribute > JSXIdentifier[name!=/^(?:n|title|children|dark|style|key|ref|className|style|children)$/]",
        "message": "<FlowStep> doesn't accept that prop. Declared props: n, title, children, dark, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|required|hint|type|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, required, hint, type, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Kicker'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|pill|style|key|ref|className|style|children)$/]",
        "message": "<Kicker> doesn't accept that prop. Declared props: children, tone, pill, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Kicker'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:coral|mint|yellow|ivory)$/]",
        "message": "<Kicker> tone must be one of 'coral' | 'mint' | 'yellow' | 'ivory'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModuleCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|eyebrow|title|children|tone|dark|interactive|style|key|ref|className|style|children)$/]",
        "message": "<ModuleCard> doesn't accept that prop. Declared props: icon, eyebrow, title, children, tone, dark, interactive, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModuleCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:mint|coral|yellow|glass|navy)$/]",
        "message": "<ModuleCard> tone must be one of 'mint' | 'coral' | 'yellow' | 'glass' | 'navy'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatementBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|dark|align|style|key|ref|className|style|children)$/]",
        "message": "<StatementBar> doesn't accept that prop. Declared props: children, dark, align, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatementBar'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center|right)$/]",
        "message": "<StatementBar> align must be one of 'left' | 'center' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Textarea'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|required|hint|rows|style|key|ref|className|style|children)$/]",
        "message": "<Textarea> doesn't accept that prop. Declared props: label, required, hint, rows, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
